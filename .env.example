# daytrade-ai env example
# Copy to .env and fill. .env is gitignored.
#
# Paper trading only. Do NOT add real-money trading API keys here.
# Read-only / sandbox keys are fine for fetching market data.

# CCXT exchange to use for fetch-data and paper trading data feed
DAYTRADE_EXCHANGE=binance

# Read-only / public data does not need keys. Keys here are for
# higher rate limits or sandbox accounts. NEVER use a production
# key with withdraw/trade permission.
DAYTRADE_API_KEY=
DAYTRADE_API_SECRET=

# Where to cache OHLCV parquet
DAYTRADE_CACHE_DIR=data/cache

# Default timeframe + symbol for CLI
DAYTRADE_DEFAULT_SYMBOL=BTC/USDT
DAYTRADE_DEFAULT_TIMEFRAME=1h

# Backtest defaults
DAYTRADE_FEE_BPS=10        # 0.10% per side
DAYTRADE_SLIPPAGE_BPS=5    # 0.05%
DAYTRADE_INITIAL_CASH=10000
